{
  "name": "checkers-vs-ai-(gemini)",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "api:dev": "node server/api.mjs",
    "docs:swagger:generate": "node scripts/generate-openapi.mjs",
    "docs:swagger:validate": "node scripts/validate-openapi.mjs docs/openapi.yaml",
    "docs:typedoc": "typedoc --options typedoc.json",
    "docs:swagger": "npm run docs:swagger:validate",
    "docs": "npm run docs:typedoc && npm run docs:swagger"
  },
  "dependencies": {
    "@google/genai": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "@twa-dev/sdk": "^6.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "dotenv": "^16.5.0",
    "js-yaml": "^4.1.0",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "typedoc": "^0.28.14"
  }
}
